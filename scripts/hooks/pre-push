#!/usr/bin/env bash
# pre-push: refresh the local e2e-skills install so it matches HEAD being pushed.
# Delegates to scripts/dev/reinstall-skills.sh, which runs:
#   `skills remove` (no-op if not installed) + `skills add --copy` (idempotent).
# This handles both initial install (first push) and refresh (subsequent pushes).
# Wired in by scripts/dev/install-hooks.sh (sets core.hooksPath=scripts/hooks).
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
echo "==> pre-push: refreshing local e2e-skills install"
"$REPO_ROOT/scripts/dev/reinstall-skills.sh"
